# Enable rewrite engine (if needed for future use)
<IfModule mod_rewrite.c>
    RewriteEngine On
</IfModule>

# Efficient cache lifetimes — force long cache so repeat visits are fast
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    # Override any existing Cache-Control (use "always" so it applies to all responses)
    <FilesMatch "\.(css|js)$">
        Header always set Cache-Control "max-age=31536000, public, immutable"
    </FilesMatch>
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|ico|svg)$">
        Header always set Cache-Control "max-age=31536000, public, immutable"
    </FilesMatch>
</IfModule>

# Compress text responses (if mod_deflate is available)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>
